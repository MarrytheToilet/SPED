# =============================================================================
# Runtime state, logs, caches, and temporary files
# =============================================================================
logs/
log/
*.log
*.tmp
*.temp
*.bak
*.backup
*.pid
*.lock

# SQLite databases and sidecar files are local runtime state.
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm


# =============================================================================
# SPED data
# =============================================================================
# Treat all paper PDFs, parsed text, generated schemas, extraction results,
# state DBs, backups, and long-running job files as local data by default.
data/**
!data/
!data/README.md
!data/**/.gitkeep

# Legacy locations from older layouts. Keep ignored if scripts recreate them.
data_schema/**
raw_docs/
downloads/
output/
exports/
.archive/


# =============================================================================
# Large document and archive inputs/outputs
# =============================================================================
*.pdf
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.gz


# =============================================================================
# Frontend and package-manager artifacts
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.parcel-cache/
.vite/


# =============================================================================
# Notebooks, editors, OS files
