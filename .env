# ==========================
# MinerU API配置
# ==========================
MINERU_TOKEN=
MINERU_API_BASE=https://mineru.net/api/v4

# MinerU 上传配置
BATCH_SIZE=20
UPLOAD_ENABLE_FORMULA=True
UPLOAD_LANGUAGE=en
UPLOAD_LAYOUT_MODEL=doclayout_yolo
UPLOAD_ENABLE_TABLE=True
FILE_PARSE_METHOD=auto
FILE_APPLY_OCR=False

# ==========================
# 数据库配置
# ==========================
# 数据库文件路径（规范化11表结构）
DB_PATH=data/artificial_joint.db

# ==========================
# LLM API配置
# ==========================
LLM_MODEL=Pro/zai-org/GLM-5

# ---------- OpenAI 配置 ----------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.zmon.me/v1

# ---------- 硅基流动 (SiliconFlow) 配置 ----------
# 多个API Key方式（可选，用逗号分隔）
# 如果配置了此项，将轮询使用多个Key分散并发压力
SILICONFLOW_API_KEYS=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# 或者使用编号方式添加备用Key
# SILICONFLOW_API_KEY_2=sk-your-second-key
# SILICONFLOW_API_KEY_3=sk-your-third-key

# ---------- DeepSeek 配置 ----------
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ---------- 智谱AI (Zhipu/GLM) 配置 ----------
# 从 https://open.bigmodel.cn/ 获取API Key
ZHIPU_API_KEY=9f95ff51335245faaf203daec175c1f8.bN9OwFrcwreHaiyC
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4

# ==========================
# LLM 调用配置
# ==========================
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.95
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
CHUNK_MODE_MAX_TOKENS=4096

# ==========================
# 文本分块配置
# ==========================
CHUNK_SIZE=6000
CHUNK_OVERLAP=200

# ==========================
# 网络配置
# ==========================
HTTP_REQUEST_TIMEOUT=30
DOWNLOAD_RETRY=3
DOWNLOAD_TIMEOUT=300
DOWNLOAD_CHUNK_SIZE=8192
# 单一LLM超时参数；删除此行则不限制超时
LLM_CALL_TIMEOUT=600

# ==========================
# 日志配置
# ==========================
LOG_LEVEL=INFO

# ==========================
# 数据提取配置
# ==========================
# Prompt文件路径（自动使用 prompts/prompt.md）
# 输出格式：11表规范化多表JSON
# 详见：prompts/prompt.md

# 导入工具：scripts/import_json.py
# 用法：python scripts/import_json.py <json_file>


# ==================== 并行处理配置 ====================
# 稳定配置：2个worker，每个key一个，避免并发过高被ban
DEFAULT_WORKERS=2
MAX_WORKERS=2

# ==================== LLM 重试配置 ====================
# 最大重试次数
LLM_MAX_RETRIES=3
# 重试退避基数（秒）- 增加间隔避免频繁请求
LLM_RETRY_BACKOFF_BASE=10
# 重试最大等待时间（秒）
LLM_RETRY_BACKOFF_MAX=120
SILICONFLOW_ENABLE_THINKING=False

# ==================== 请求间隔配置 ====================
# 每个请求之间的最小间隔（秒）- 避免请求过于密集
LLM_MIN_INTERVAL=3.0

# ==================== 骨架提取采样配置 ====================
# 触发采样的长度阈值
SKELETON_MAX_LENGTH=60000
# 开头保留字符数（摘要+引言+方法开头）
SKELETON_HEAD_CHARS=10000
# 剩余内容采样比例
SKELETON_SAMPLE_RATIO=0.8
# 硬截断阈值
SKELETON_HARD_LIMIT=60000
