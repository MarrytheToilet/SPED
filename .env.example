# SPED environment template.
# Copy to `.env` and fill secrets. Lines starting with `#` are comments.

# =============================================================================
# Data layout
# =============================================================================

# Default collection/theme. Web and CLI use this when no collection is selected.
# Files are stored under:
#   data/collections/<DEFAULT_COLLECTION>/pdfs/
#   data/collections/<DEFAULT_COLLECTION>/parsed/
#   data/collections/<DEFAULT_COLLECTION>/schemas/
#   data/collections/<DEFAULT_COLLECTION>/extracted/<schema_slug>/
DEFAULT_COLLECTION=人工关节材料摩擦学

# Web server port. If occupied, start uvicorn manually with another port.
WEB_PORT=8000


# =============================================================================
# MinerU PDF parsing
# =============================================================================

# MinerU API token. Required for PDF upload/parse.
MINERU_TOKEN=your_mineru_token_here

# MinerU OpenAPI endpoint.
MINERU_API_BASE=https://mineru.net/api/v4

# Maximum PDF size accepted by Web/CLI upload, in MB.
# Larger files are shown as "too large" and skipped to avoid expensive failures.
MAX_PDF_SIZE_MB=20

# If a PDF remains uploaded/processing longer than this many hours,
# the Web overview marks it as failed so it can be retried or cleaned.
PROCESSING_STALE_HOURS=12

# MinerU upload rate limit. MinerU is commonly limited to about 50 files/min.
MINERU_UPLOAD_RATE_PER_MIN=50

# Upload batch planning.
# BATCH_SIZE is a hard per-batch count cap; BATCH_MAX_TOTAL_MB spreads large files.
BATCH_SIZE=200
BATCH_MAX_TOTAL_MB=120

# MinerU parsing options.
UPLOAD_ENABLE_FORMULA=True
UPLOAD_LANGUAGE=en
UPLOAD_LAYOUT_MODEL=doclayout_yolo
UPLOAD_ENABLE_TABLE=True
FILE_PARSE_METHOD=auto
FILE_APPLY_OCR=False


# =============================================================================
# Base LLM endpoint
# =============================================================================

# Any OpenAI-compatible endpoint can be used here.
# Role-specific agents below inherit these values unless overridden.
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-flash
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here

# Sampling/decoding.
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.95

# Process-wide LLM request cap across all running jobs.
# Keep this <= provider rate limit. Extraction workers each make LLM calls.
LLM_MAX_INFLIGHT=8

# Large default avoids empty/truncated responses from reasoning-capable models.
LLM_MAX_OUTPUT_TOKENS=65536

# Optional timeout for a single LLM call, seconds. Empty means SDK default/no cap.
# LLM_CALL_TIMEOUT=600

# Retry policy for LLM calls.
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=10
LLM_RETRY_BACKOFF_MAX=120
LLM_RETRY_MAX_TOKENS_DECAY=0.7

# Minimum interval between calls inside one LLM client.
LLM_MIN_INTERVAL=3.0


# =============================================================================
# Multi-agent roles
# =============================================================================

# Schema discovery:
# 1) schema_agent_a/b/c independently read the same sampled papers and draft schemas.
# 2) schema_merger merges drafts into one schema.
# 3) schema_reviewer reviews the merged schema.
SCHEMA_AGENT_ROLES=schema_agent_a,schema_agent_b,schema_agent_c
SCHEMA_MERGER_ROLE=schema_merger
SCHEMA_REVIEWER_ROLE=schema_reviewer

# Extraction:
# 1) extractor_a/b independently extract records.
# 2) extract_merger merges when two or more extractors are enabled.
# 3) extract_reviewer reviews records against evidence when enabled.
EXTRACTOR_ROLES=extractor_a,extractor_b
EXTRACT_MERGER_ROLE=extract_merger
EXTRACT_REVIEWER_ROLE=extract_reviewer
EXTRACT_REVIEW_ENABLED=true

# Role-specific endpoint override format:
#   AGENT_<ROLE>_MODEL=...
#   AGENT_<ROLE>_API_BASE=...
#   AGENT_<ROLE>_API_KEY=...
#
# Example: use another model for one schema agent.
# AGENT_SCHEMA_AGENT_B_MODEL=qwen-max
# AGENT_SCHEMA_AGENT_B_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# AGENT_SCHEMA_AGENT_B_API_KEY=your_qwen_key


# =============================================================================
# Schema discovery
# =============================================================================

# Target field count range for generated schemas.
SCHEMA_MIN_FIELDS=20
SCHEMA_MAX_FIELDS=80

# Number of parsed papers sampled for schema discovery.
SCHEMA_SAMPLE_SIZE=8

# Per-paper character budget for abstract/introduction/experimental/method snippets.
SCHEMA_EXCERPT_BUDGET=16000


# =============================================================================
# Extraction
# =============================================================================

# Number of papers processed concurrently during extraction.
# This is separate from LLM_MAX_INFLIGHT. Effective parallel LLM calls are capped by both.
EXTRACT_CONCURRENCY=8

# Maximum characters sent to extraction LLM per paper. 0 means no truncation.
EXTRACT_MAX_INPUT_CHARS=0


# =============================================================================
# Network retries and timeouts
# =============================================================================

HTTP_REQUEST_TIMEOUT=20

DOWNLOAD_RETRY=2
DOWNLOAD_TIMEOUT=180
DOWNLOAD_CHUNK_SIZE=8192
DOWNLOAD_RETRY_BACKOFF_BASE=1.8
DOWNLOAD_RETRY_BACKOFF_MAX=8

UPLOAD_RETRY=2
UPLOAD_RETRY_BACKOFF_BASE=1.8
UPLOAD_RETRY_BACKOFF_MAX=8


# =============================================================================
# Logging and optional provider-specific knobs
# =============================================================================

LOG_LEVEL=INFO

# SiliconFlow reasoning controls. Only used by models/providers that support them.
SILICONFLOW_ENABLE_THINKING=False
SILICONFLOW_THINKING_BUDGET=1024
