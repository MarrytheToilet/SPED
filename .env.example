# ==========================
# MinerU API 配置（PDF → Markdown 解析）
# ==========================
MINERU_TOKEN=your_mineru_token_here
MINERU_API_BASE=https://mineru.net/api/v4

# MinerU 上传/解析配置
BATCH_SIZE=200
MAX_PDF_SIZE_MB=20                # 单个 PDF 体积上限；超过则不予上传解析
MINERU_UPLOAD_RATE_PER_MIN=50     # MinerU 上传速率上限（文件/分钟），规避 429
UPLOAD_ENABLE_FORMULA=True
UPLOAD_LANGUAGE=en
UPLOAD_LAYOUT_MODEL=doclayout_yolo
UPLOAD_ENABLE_TABLE=True
FILE_PARSE_METHOD=auto
FILE_APPLY_OCR=False

# ==========================
# LLM 配置（OpenAI 兼容即可）
# ==========================
LLM_MODEL=deepseek-v4-flash
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here

# ==========================
# 多智能体（可选）—— 不填则全部回退到上面的基础 LLM_* 配置
# 角色: PROPOSER_A / PROPOSER_B / PROPOSER_C / CONSOLIDATOR / CRITIC / EXTRACTOR
# 为某角色配置不同模型家族，只需填它自己的 MODEL/API_BASE/API_KEY：
# ==========================
# AGENT_PROPOSER_B_MODEL=...
# AGENT_PROPOSER_B_API_BASE=...
# AGENT_PROPOSER_B_API_KEY=...

# ==========================
# 可选调参
# ==========================
# LLM_MAX_OUTPUT_TOKENS=65536   # 推理模型给足额度，避免截断
# SCHEMA_MIN_FIELDS=20          # 自动设计 schema 的字段数下限
# SCHEMA_MAX_FIELDS=80          # 字段数上限
# SCHEMA_SAMPLE_SIZE=8          # 设计 schema 时采样论文篇数
# SCHEMA_EXCERPT_BUDGET=16000   # 每篇论文进入上下文的字符预算
# EXTRACT_CONCURRENCY=8         # 提取阶段并行篇数（每worker独立LLM客户端，1–32）；DeepSeek 建议 8–16
# LLM_CALL_TIMEOUT=600          # 单次 LLM 调用超时(秒)；避免个别慢响应长时间占用worker
# MAX_WORKERS=4
